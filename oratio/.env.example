# ==============================================
# Oratio Environment Configuration
# ==============================================
# 방법 1 (권장): refresh_passwords.sh로 자동 생성
#   cp refresh_passwords.sh.example refresh_passwords.sh
#   nano refresh_passwords.sh   # [CHANGE_ME] 항목 수정 (도메인, 지갑 등)
#   chmod +x refresh_passwords.sh
#   ./refresh_passwords.sh      # .env 자동 생성 + 비밀번호 자동 생성
#
# 방법 2 (수동): 이 파일을 복사해서 직접 값 채우기
#   cp .env.example .env
#   nano .env
# ==============================================

# --- PostgreSQL ---
POSTGRES_USER=lemmy
POSTGRES_PASSWORD=          # REQUIRED: generate a strong random password
POSTGRES_DB=lemmy

# --- Electron Cash (BCH Wallet) ---
ELECTRON_CASH_USER=bchrpc
ELECTRON_CASH_PASSWORD=     # REQUIRED: generate a strong random password

# --- Lemmy Integration ---
LEMMY_API_KEY=              # REQUIRED: shared secret between UI and payment service
LEMMY_BCH_API_KEY=          # usually same as LEMMY_API_KEY
LEMMY_ADMIN_USER=admin
LEMMY_ADMIN_PASS=           # REQUIRED: Lemmy admin password

# --- BCH Payment URLs ---
# These must match your domain. Change "oratio.space" to your domain.
LEMMY_BCH_API_URL=https://YOUR_DOMAIN/payments/api/user_credit
LEMMY_BCH_PAYMENT_URL=https://YOUR_DOMAIN/payments/

# --- Email (Resend API) ---
SMTP_SERVER=email-service:1025
SMTP_FROM_ADDRESS=noreply@YOUR_DOMAIN
SMTP_USERNAME=
SMTP_PASSWORD=
ADMIN_EMAIL=admin@YOUR_DOMAIN
RESEND_API_KEY=             # REQUIRED if using email verification (https://resend.com)

# --- Site Info ---
SITE_NAME=Oratio
SITE_DESCRIPTION=A forum for meaningful discussions
DOMAIN=YOUR_DOMAIN          # e.g. oratio.space

# --- Flask (Payment Service) ---
FLASK_SECRET_KEY=           # REQUIRED: generate a strong random string

# --- BCH Payment Options ---
MOCK_MODE=false             # true = fake payments for testing
TESTNET=false               # true = use BCH testnet
PAYOUT_WALLET=              # REQUIRED: your BCH address (bitcoincash:q...)

# --- Misc ---
NODE_ENV=production
COMMIT_HASH=latest

# --- Content Importer (Bootstrapping) ---
LEMMY_BOT_USERNAME=OratioRepostBot
LEMMY_BOT_PASSWORD=         # REQUIRED if using content importer
LEMMY_DEFAULT_COMMUNITY=trending
IMPORT_INTERVAL_MINUTES=360 # 6 hours between import cycles
IMPORT_ON_STARTUP=true      # Run an import cycle on service start

# AI-based post selection (optional — falls back to score-based ranking)
AI_ENABLED=false            # true = use AI to pick most interesting posts
AI_PROVIDER=openai          # "openai" | "anthropic" | "gemini"
OPENAI_API_KEY=             # Required if AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini    # Cheapest model that supports JSON mode
GEMINI_API_KEY=             # Required if AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# YouTube Data API v3 (free: 10k units/day — https://console.cloud.google.com)
YOUTUBE_API_KEY=            # Required for YouTube trending source

# Comment importing (score-based top N from source websites, no AI needed)
COMMENTS_ENABLED=true       # Import top comments alongside posts
COMMENTS_PER_POST=3         # Number of top comments per post

# Pictrs (image hosting) API key — auto-generated, must match lemmy.hjson
PICTRS_API_KEY=             # REQUIRED: generate a random string
