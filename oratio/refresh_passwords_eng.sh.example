#!/bin/bash

# ============================================================
# refresh_passwords.sh.example_eng
# ============================================================
# Copy this file to refresh_passwords.sh and run it.
# It will auto-generate a .env file and securely reset all passwords.
#
# Usage:
#   cp refresh_passwords.sh.example_eng refresh_passwords.sh
#   nano refresh_passwords.sh   # Edit [CHANGE_ME] values below
#   chmod +x refresh_passwords.sh
#   ./refresh_passwords.sh
#
# ⚠️  Warning: Running this script will overwrite the existing .env and passwords.
#   The existing .env will be automatically backed up as .env.bak.
# ============================================================

# ========================
# [CHANGE_ME] User Settings
# ========================

# Domain (change to your own domain)
DOMAIN="your-domain.com"

# Admin email (for Let's Encrypt and site administration)
ADMIN_EMAIL="admin@your-domain.com"

# Resend API key (email delivery service — get one at https://resend.com)
# Leave empty if email verification is not needed
RESEND_API_KEY_VALUE=""

# BCH payout wallet address (where collected payments are forwarded)
PAYOUT_WALLET_ADDRESS="bitcoincash:your_payout_address_here"

# SMTP sender address
SMTP_FROM="noreply@${DOMAIN}"

# Site information
SITE_NAME_VALUE="Oratio"
SITE_DESCRIPTION_VALUE="A forum for meaningful discussions"

# ========================
# Password Generation Functions
# ========================

generate_password() {
  local length=${1:-32}
  openssl rand -base64 48 | tr -d '\n' | tr -d ' ' | head -c "$length"
}

generate_strong_password() {
  local length=${1:-40}
  (openssl rand -base64 32; openssl rand -hex 16) | tr -d '\n' | head -c "$length"
}

# ========================
# Path Configuration
# ========================

# Set paths relative to the script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORATIO_ENV_FILE="${SCRIPT_DIR}/.env"
LEMMY_UI_ENV_FILE="${SCRIPT_DIR}/../lemmy-ui-custom/.env"

# ========================
# Generate Passwords
# ========================

NEW_ELECTRON_CASH_PASSWORD=$(generate_password 24)
NEW_LEMMY_API_KEY=$(generate_strong_password 32)
NEW_LEMMY_ADMIN_PASS=$(generate_password 24)
NEW_FLASK_SECRET_KEY=$(generate_strong_password 40)
NEW_POSTGRES_PASSWORD=$(generate_password 32)

echo "🔐 Generating new passwords..."

# Generate admin bcrypt hash (using PostgreSQL pgcrypto)
NEW_ADMIN_BCRYPT_HASH=$(docker-compose exec -T postgres psql -U lemmy -d lemmy -tA -c \
    "SELECT crypt('$NEW_LEMMY_ADMIN_PASS', gen_salt('bf', 12));" 2>/dev/null | tr -d '\r\n')

if [ -n "$NEW_ADMIN_BCRYPT_HASH" ]; then
    NEW_ADMIN_BCRYPT_HASH=$(echo "$NEW_ADMIN_BCRYPT_HASH" | sed 's/^\$2a\$/\$2b\$/')
    echo "✅ bcrypt hash generated successfully (pgcrypto)"
fi

# Fallback: Python bcrypt
if [ -z "$NEW_ADMIN_BCRYPT_HASH" ]; then
    echo "⚠️  pgcrypto failed, trying Python bcrypt..."
    NEW_ADMIN_BCRYPT_HASH=$(docker-compose exec -T bitcoincash-service python3 -c "
try:
    import bcrypt
except ImportError:
    import subprocess, sys
    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q', 'bcrypt'], 
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    import bcrypt
password = b'$NEW_LEMMY_ADMIN_PASS'
salt = bcrypt.gensalt(rounds=12)
hash_bytes = bcrypt.hashpw(password, salt)
print(hash_bytes.decode('utf-8'))
" 2>/dev/null | tr -d '\r\n')
    if [ -n "$NEW_ADMIN_BCRYPT_HASH" ]; then
        echo "✅ bcrypt hash generated successfully (Python bcrypt)"
    fi
fi

if [ -z "$NEW_ADMIN_BCRYPT_HASH" ]; then
    echo "❌ bcrypt hash generation failed. Keeping existing password."
    if [ -f "$ORATIO_ENV_FILE" ]; then
        EXISTING_PASS=$(grep '^LEMMY_ADMIN_PASS=' "$ORATIO_ENV_FILE" | cut -d= -f2)
        if [ -n "$EXISTING_PASS" ]; then
            NEW_LEMMY_ADMIN_PASS="$EXISTING_PASS"
        fi
    fi
else
    echo "✅ Admin password will be synced to both .env and PostgreSQL"
fi

# ========================
# Backup Existing .env
# ========================

if [ -f "$ORATIO_ENV_FILE" ]; then
    cp "$ORATIO_ENV_FILE" "${ORATIO_ENV_FILE}.bak"
    echo "Backed up existing oratio .env to ${ORATIO_ENV_FILE}.bak"
fi

if [ -f "$LEMMY_UI_ENV_FILE" ]; then
    cp "$LEMMY_UI_ENV_FILE" "${LEMMY_UI_ENV_FILE}.bak"
    echo "Backed up existing lemmy-ui-custom .env to ${LEMMY_UI_ENV_FILE}.bak"
fi

# ========================
# Generate .env File
# ========================

generate_env_content() {
cat << EOF
# ==============================================
# Shared Environment Configuration
# Used by both lemmy-ui-custom and oratio
# Generated: $(date '+%Y-%m-%d %H:%M:%S')
# ==============================================

# PostgreSQL Settings
POSTGRES_USER=lemmy
POSTGRES_PASSWORD=$NEW_POSTGRES_PASSWORD
POSTGRES_DB=lemmy

# Electron Cash Settings
ELECTRON_CASH_USER=bchrpc
ELECTRON_CASH_PASSWORD=$NEW_ELECTRON_CASH_PASSWORD

# Lemmy Integration Settings
LEMMY_API_KEY=$NEW_LEMMY_API_KEY
LEMMY_BCH_API_KEY=$NEW_LEMMY_API_KEY
LEMMY_ADMIN_USER=admin
LEMMY_ADMIN_PASS=$NEW_LEMMY_ADMIN_PASS
# BCH payment service URL — served under subpath
LEMMY_BCH_API_URL=https://${DOMAIN}/payments/api/user_credit
LEMMY_BCH_PAYMENT_URL=https://${DOMAIN}/payments/

# Email Configuration
SMTP_SERVER=email-service:1025
SMTP_FROM_ADDRESS=${SMTP_FROM}
SMTP_USERNAME=
SMTP_PASSWORD=
ADMIN_EMAIL=${ADMIN_EMAIL}
SITE_NAME=${SITE_NAME_VALUE}
SITE_DESCRIPTION=${SITE_DESCRIPTION_VALUE}
DOMAIN=${DOMAIN}

# Resend API Configuration
RESEND_API_KEY=${RESEND_API_KEY_VALUE}

# Flask Settings
FLASK_SECRET_KEY=$NEW_FLASK_SECRET_KEY

# Other Settings
MOCK_MODE=false
TESTNET=false
PAYOUT_WALLET=${PAYOUT_WALLET_ADDRESS}
NODE_ENV=production
COMMIT_HASH=latest
EOF
}

generate_env_content > "$ORATIO_ENV_FILE"
generate_env_content > "$LEMMY_UI_ENV_FILE"

# ========================
# Sync lemmy.hjson DB Password
# ========================

LEMMY_HJSON_FILE="${SCRIPT_DIR}/lemmy.hjson"
if [ -f "$LEMMY_HJSON_FILE" ]; then
    echo "🔄 Updating PostgreSQL password in lemmy.hjson..."
    sed -i "s|password: \".*\"|password: \"$NEW_POSTGRES_PASSWORD\"|" "$LEMMY_HJSON_FILE"
    if [ $? -eq 0 ]; then
        echo "✅ lemmy.hjson password updated"
    else
        echo "⚠️  Failed to update lemmy.hjson. Please check manually"
    fi
else
    echo "⚠️  lemmy.hjson not found: $LEMMY_HJSON_FILE"
fi

echo ""
echo "✅ New passwords generated and saved to .env files."
echo "📍 Generated files:"
echo "   - $ORATIO_ENV_FILE"
echo "   - $LEMMY_UI_ENV_FILE"
echo ""
echo "🔐 Generated password info:"
echo "   - PostgreSQL Password: ${#NEW_POSTGRES_PASSWORD} chars"
echo "   - Electron Cash Password: ${#NEW_ELECTRON_CASH_PASSWORD} chars"
echo "   - Lemmy API Key: ${#NEW_LEMMY_API_KEY} chars"
echo "   - Admin Password: ${#NEW_LEMMY_ADMIN_PASS} chars"
echo "   - Flask Secret Key: ${#NEW_FLASK_SECRET_KEY} chars"
echo ""

# ========================
# Recreate Containers (Apply New Env Vars)
# ========================

echo "🔄 Recreating containers to apply new environment variables..."
cd "$SCRIPT_DIR"

echo "  [1/6] Recreating postgres..."
docker-compose up -d --force-recreate postgres 2>&1
echo "  ⏳ Waiting for PostgreSQL to be ready (up to 30s)..."
for i in $(seq 1 30); do
    if docker exec -i oratio-postgres-1 pg_isready -U lemmy >/dev/null 2>&1; then
        echo "  ✅ PostgreSQL ready (${i}s)"
        break
    fi
    sleep 1
done

echo "  [2/6] Syncing PostgreSQL user password..."
docker-compose exec -T postgres psql -U lemmy -d lemmy -c \
    "ALTER USER lemmy WITH PASSWORD '$NEW_POSTGRES_PASSWORD';" >/dev/null 2>&1
if [ $? -eq 0 ]; then
    echo "  ✅ PostgreSQL user password synced"
else
    echo "  ❌ PostgreSQL user password sync failed!"
fi

if [ -n "$NEW_ADMIN_BCRYPT_HASH" ]; then
    echo "  🔄 Updating PostgreSQL admin password bcrypt hash..."
    docker-compose exec -T postgres psql -U lemmy -d lemmy -c \
        "UPDATE local_user SET password_encrypted = '$NEW_ADMIN_BCRYPT_HASH' \
         WHERE person_id = (SELECT id FROM person WHERE name = 'admin');" >/dev/null 2>&1
    if [ $? -eq 0 ]; then
        echo "  ✅ PostgreSQL admin password updated"
    else
        echo "  ⚠️  PostgreSQL admin password update failed"
    fi
fi

echo "  [3/6] Recreating lemmy backend..."
docker-compose up -d --force-recreate lemmy 2>&1
sleep 3

echo "  [4/6] Rebuilding lemmy-ui image..."
docker-compose stop lemmy-ui 2>&1
docker-compose rm -f lemmy-ui 2>&1
docker rmi lemmy-ui-custom:latest 2>/dev/null
docker-compose build --no-cache lemmy-ui 2>&1 | tail -5

echo "  [5/6] Starting lemmy-ui frontend..."
docker-compose up -d lemmy-ui 2>&1

echo "  [6/6] Recreating bitcoincash-service..."
docker-compose up -d --force-recreate bitcoincash-service 2>&1

echo ""
echo "✅ All services recreated"

# Final health check
echo ""
echo "🔍 Checking service status..."
sleep 5

if docker exec -i oratio-postgres-1 pg_isready -U lemmy >/dev/null 2>&1; then
    echo "  ✅ PostgreSQL: OK"
else
    echo "  ❌ PostgreSQL: NOT OK"
fi

LEMMY_STATUS=$(docker ps --filter "name=oratio-lemmy-1" --format "{{.Status}}")
echo "  ℹ️  Lemmy: $LEMMY_STATUS"

LEMMYUI_STATUS=$(docker ps --filter "name=oratio-lemmy-ui-1" --format "{{.Status}}")
echo "  ℹ️  Lemmy-UI: $LEMMYUI_STATUS"

echo ""
echo "🎉 Done! Site: https://${DOMAIN}"
echo ""
echo "⚠️  Notes:"
echo "   - RESEND_API_KEY uses the value you configured"
echo "   - PAYOUT_WALLET uses the value you configured"
echo "   - Admin login: admin / (password generated above)"
