{
  # Lemmy configuration - https://join-lemmy.org/docs/en/administration/configuration.html
  # Copy this file to lemmy.hjson and fill in your values:
  #   cp lemmy.hjson.example lemmy.hjson

  database: {
    host: postgres
    port: 5432
    user: "lemmy"
    password: "CHANGE_ME"       # Must match POSTGRES_PASSWORD in .env
    database: "lemmy"
    pool_size: 5
  }

  # Change to your domain
  hostname: "YOUR_DOMAIN"

  bind: "0.0.0.0"
  port: 8536

  # SSL cert paths (mounted from certbot volume)
  # Comment these out if running without SSL initially
  # cert_path: "/etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem"
  # key_path: "/etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem"

  pictrs: {
    url: "http://pictrs:8080/"
    api_key: "CHANGE_ME"        # Must match PICTRS__SERVER__API_KEY in docker-compose.yml
  }

  email: {
    smtp_server: "email-service:1025"
    smtp_from_address: "noreply@YOUR_DOMAIN"
    tls_type: "none"
  }

  registration_mode: "RequireApplication"
  require_email_verification: true
  application_email_admins: true

  federation: {
    enabled: false
  }

  captcha: {
    enabled: true
    difficulty: "medium"
  }

  rate_limit: {
    message: 180
    message_per_second: 60
    post: 6
    post_per_second: 600
    register: 3
    register_per_second: 3600
    image: 6
    image_per_second: 3600
    comment: 6
    comment_per_second: 600
    search: 60
    search_per_second: 600
  }
}
