#!/bin/bash

# ============================================================
# refresh_passwords.sh.example
# ============================================================
# 이 파일을 refresh_passwords.sh로 복사한 뒤 실행하면
# .env 파일이 자동 생성되고 모든 비밀번호가 안전하게 재설정됩니다.
#
# 사용법:
#   cp refresh_passwords.sh.example refresh_passwords.sh
#   nano refresh_passwords.sh   # 아래 [CHANGE_ME] 항목 수정
#   chmod +x refresh_passwords.sh
#   ./refresh_passwords.sh
#
# ⚠️  주의: 이 스크립트를 실행하면 기존 .env와 비밀번호가 덮어쓰여집니다.
#   기존 .env는 .env.bak으로 자동 백업됩니다.
# ============================================================

# ========================
# [CHANGE_ME] 사용자 설정
# ========================

# 도메인 (본인 도메인으로 변경)
DOMAIN="your-domain.com"

# 관리자 이메일 (Let's Encrypt, 사이트 관리용)
ADMIN_EMAIL="admin@your-domain.com"

# Resend API 키 (이메일 발송 서비스 — https://resend.com 에서 발급)
# 이메일 인증이 필요 없으면 빈 문자열로 두세요
RESEND_API_KEY_VALUE=""

# BCH 수금 지갑 주소 (결제금 자동 전송 대상)
PAYOUT_WALLET_ADDRESS="bitcoincash:your_payout_address_here"

# SMTP 발신 주소
SMTP_FROM="noreply@${DOMAIN}"

# 사이트 정보
SITE_NAME_VALUE="Oratio"
SITE_DESCRIPTION_VALUE="A forum for meaningful discussions"

# ========================
# 비밀번호 자동 생성 함수
# ========================

generate_password() {
  local length=${1:-32}
  openssl rand -base64 48 | tr -d '\n' | tr -d ' ' | head -c "$length"
}

generate_strong_password() {
  local length=${1:-40}
  (openssl rand -base64 32; openssl rand -hex 16) | tr -d '\n' | head -c "$length"
}

# ========================
# 경로 설정
# ========================

# 스크립트가 있는 디렉터리 기준으로 경로 설정
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORATIO_ENV_FILE="${SCRIPT_DIR}/.env"
LEMMY_UI_ENV_FILE="${SCRIPT_DIR}/../lemmy-ui-custom/.env"

# ========================
# 비밀번호 생성
# ========================

NEW_ELECTRON_CASH_PASSWORD=$(generate_password 24)
NEW_LEMMY_API_KEY=$(generate_strong_password 32)
NEW_LEMMY_ADMIN_PASS=$(generate_password 24)
NEW_FLASK_SECRET_KEY=$(generate_strong_password 40)
NEW_POSTGRES_PASSWORD=$(generate_password 32)
NEW_LEMMY_BOT_PASSWORD=$(generate_password 24)
NEW_PICTRS_API_KEY=$(generate_password 20)

echo "🔐 새 비밀번호 생성 중..."

# Admin bcrypt hash 생성 (PostgreSQL pgcrypto 사용)
NEW_ADMIN_BCRYPT_HASH=$(docker-compose exec -T postgres psql -U lemmy -d lemmy -tA -c \
    "SELECT crypt('$NEW_LEMMY_ADMIN_PASS', gen_salt('bf', 12));" 2>/dev/null | tr -d '\r\n')

if [ -n "$NEW_ADMIN_BCRYPT_HASH" ]; then
    NEW_ADMIN_BCRYPT_HASH=$(echo "$NEW_ADMIN_BCRYPT_HASH" | sed 's/^\$2a\$/\$2b\$/')
    echo "✅ bcrypt hash 생성 완료 (pgcrypto)"
fi

# Fallback: Python bcrypt
if [ -z "$NEW_ADMIN_BCRYPT_HASH" ]; then
    echo "⚠️  pgcrypto 실패, Python bcrypt로 시도..."
    NEW_ADMIN_BCRYPT_HASH=$(docker-compose exec -T bitcoincash-service python3 -c "
try:
    import bcrypt
except ImportError:
    import subprocess, sys
    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q', 'bcrypt'], 
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    import bcrypt
password = b'$NEW_LEMMY_ADMIN_PASS'
salt = bcrypt.gensalt(rounds=12)
hash_bytes = bcrypt.hashpw(password, salt)
print(hash_bytes.decode('utf-8'))
" 2>/dev/null | tr -d '\r\n')
    if [ -n "$NEW_ADMIN_BCRYPT_HASH" ]; then
        echo "✅ bcrypt hash 생성 완료 (Python bcrypt)"
    fi
fi

if [ -z "$NEW_ADMIN_BCRYPT_HASH" ]; then
    echo "❌ bcrypt hash 생성 실패. 기존 패스워드 유지합니다."
    if [ -f "$ORATIO_ENV_FILE" ]; then
        EXISTING_PASS=$(grep '^LEMMY_ADMIN_PASS=' "$ORATIO_ENV_FILE" | cut -d= -f2)
        if [ -n "$EXISTING_PASS" ]; then
            NEW_LEMMY_ADMIN_PASS="$EXISTING_PASS"
        fi
    fi
else
    echo "✅ admin 패스워드가 .env와 PostgreSQL 양쪽에 동기화됩니다"
fi

# ========================
# 기존 .env 백업
# ========================

if [ -f "$ORATIO_ENV_FILE" ]; then
    cp "$ORATIO_ENV_FILE" "${ORATIO_ENV_FILE}.bak"
    echo "기존 oratio .env 파일을 ${ORATIO_ENV_FILE}.bak으로 백업했습니다."
fi

if [ -f "$LEMMY_UI_ENV_FILE" ]; then
    cp "$LEMMY_UI_ENV_FILE" "${LEMMY_UI_ENV_FILE}.bak"
    echo "기존 lemmy-ui-custom .env 파일을 ${LEMMY_UI_ENV_FILE}.bak으로 백업했습니다."
fi

# ========================
# .env 파일 생성
# ========================

generate_env_content() {
cat << EOF
# ==============================================
# 공통 환경설정 파일
# lemmy-ui-custom과 oratio에서 공유하는 설정
# 생성일: $(date '+%Y-%m-%d %H:%M:%S')
# ==============================================

# PostgreSQL 설정
POSTGRES_USER=lemmy
POSTGRES_PASSWORD=$NEW_POSTGRES_PASSWORD
POSTGRES_DB=lemmy

# Electron Cash 설정
ELECTRON_CASH_USER=bchrpc
ELECTRON_CASH_PASSWORD=$NEW_ELECTRON_CASH_PASSWORD

# Lemmy 연동 설정
LEMMY_API_KEY=$NEW_LEMMY_API_KEY
LEMMY_BCH_API_KEY=$NEW_LEMMY_API_KEY
LEMMY_ADMIN_USER=admin
LEMMY_ADMIN_PASS=$NEW_LEMMY_ADMIN_PASS
# BCH 결제 서비스 URL - 서브경로로 서비스
LEMMY_BCH_API_URL=https://${DOMAIN}/payments/api/user_credit
LEMMY_BCH_PAYMENT_URL=https://${DOMAIN}/payments/

# Email Configuration
SMTP_SERVER=email-service:1025
SMTP_FROM_ADDRESS=${SMTP_FROM}
SMTP_USERNAME=
SMTP_PASSWORD=
ADMIN_EMAIL=${ADMIN_EMAIL}
SITE_NAME=${SITE_NAME_VALUE}
SITE_DESCRIPTION=${SITE_DESCRIPTION_VALUE}
DOMAIN=${DOMAIN}

# Resend API Configuration
RESEND_API_KEY=${RESEND_API_KEY_VALUE}

# Flask 설정
FLASK_SECRET_KEY=$NEW_FLASK_SECRET_KEY

# Content Importer (Bootstrapping) 설정
LEMMY_BOT_USERNAME=OratioRepostBot
LEMMY_BOT_PASSWORD=$NEW_LEMMY_BOT_PASSWORD
LEMMY_DEFAULT_COMMUNITY=trending
IMPORT_INTERVAL_MINUTES=360
IMPORT_ON_STARTUP=true
AI_ENABLED=false
AI_PROVIDER=gemini
GEMINI_API_KEY=             # Get from Google AI Studio (free tier available)
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
YOUTUBE_API_KEY=            # Get from Google Cloud Console (free: 10k units/day)
COMMENTS_ENABLED=true
COMMENTS_PER_POST=3
IMPORTER_API_KEY=\$NEW_LEMMY_API_KEY
RUMBLE_USERNAME=
RUMBLE_PASSWORD=
IMGUR_CLIENT_ID=

# 기타 설정
MOCK_MODE=false
TESTNET=false
PAYOUT_WALLET=\${PAYOUT_WALLET_ADDRESS}
NODE_ENV=production
COMMIT_HASH=latest
PICTRS_API_KEY=\$NEW_PICTRS_API_KEY
EOF
}

generate_env_content > "$ORATIO_ENV_FILE"
generate_env_content > "$LEMMY_UI_ENV_FILE"

# ========================
# lemmy.hjson DB 비밀번호 동기화
# ========================

LEMMY_HJSON_FILE="${SCRIPT_DIR}/lemmy.hjson"
if [ -f "$LEMMY_HJSON_FILE" ]; then
    echo "🔄 lemmy.hjson PostgreSQL 비밀번호 업데이트 중..."
    sed -i "s|password: \".*\"|password: \"$NEW_POSTGRES_PASSWORD\"|" "$LEMMY_HJSON_FILE"
    sed -i "s|api_key: \".*\"|api_key: \"$NEW_PICTRS_API_KEY\"|" "$LEMMY_HJSON_FILE"
    if [ $? -eq 0 ]; then
        echo "✅ lemmy.hjson 비밀번호 업데이트 완료"
    else
        echo "⚠️  lemmy.hjson 업데이트 실패. 수동으로 확인 필요"
    fi
else
    echo "⚠️  lemmy.hjson 파일을 찾을 수 없음: $LEMMY_HJSON_FILE"
fi

echo ""
echo "✅ 새 비밀번호가 생성되어 .env 파일에 저장되었습니다."
echo "📍 생성된 파일:"
echo "   - $ORATIO_ENV_FILE"
echo "   - $LEMMY_UI_ENV_FILE"
echo ""
echo "🔐 생성된 비밀번호 정보:"
echo "   - PostgreSQL Password: ${#NEW_POSTGRES_PASSWORD}자리"
echo "   - Electron Cash Password: ${#NEW_ELECTRON_CASH_PASSWORD}자리"
echo "   - Lemmy API Key: ${#NEW_LEMMY_API_KEY}자리"
echo "   - Admin Password: ${#NEW_LEMMY_ADMIN_PASS}자리"
echo "   - Flask Secret Key: ${#NEW_FLASK_SECRET_KEY}자리"
echo ""

# ========================
# 컨테이너 재생성 (환경변수 적용)
# ========================

echo "🔄 새 환경변수를 적용하기 위해 컨테이너를 재생성합니다..."
cd "$SCRIPT_DIR"

echo "  [1/6] postgres 재생성 중..."
docker-compose up -d --force-recreate postgres 2>&1
echo "  ⏳ PostgreSQL 준비 대기 (최대 30초)..."
for i in $(seq 1 30); do
    if docker exec -i oratio-postgres-1 pg_isready -U lemmy >/dev/null 2>&1; then
        echo "  ✅ PostgreSQL 준비 완료 (${i}초)"
        break
    fi
    sleep 1
done

echo "  [2/6] PostgreSQL 유저 비밀번호 동기화 중..."
docker-compose exec -T postgres psql -U lemmy -d lemmy -c \
    "ALTER USER lemmy WITH PASSWORD '$NEW_POSTGRES_PASSWORD';" >/dev/null 2>&1
if [ $? -eq 0 ]; then
    echo "  ✅ PostgreSQL 유저 비밀번호 동기화 완료"
else
    echo "  ❌ PostgreSQL 유저 비밀번호 동기화 실패!"
fi

if [ -n "$NEW_ADMIN_BCRYPT_HASH" ]; then
    echo "  🔄 PostgreSQL admin 패스워드 bcrypt hash 업데이트 중..."
    docker-compose exec -T postgres psql -U lemmy -d lemmy -c \
        "UPDATE local_user SET password_encrypted = '$NEW_ADMIN_BCRYPT_HASH' \
         WHERE person_id = (SELECT id FROM person WHERE name = 'admin');" >/dev/null 2>&1
    if [ $? -eq 0 ]; then
        echo "  ✅ PostgreSQL admin 패스워드 업데이트 완료"
    else
        echo "  ⚠️  PostgreSQL admin 패스워드 업데이트 실패"
    fi
fi

echo "  [3/6] lemmy 백엔드 재생성 중..."
docker-compose up -d --force-recreate lemmy 2>&1
sleep 3

echo "  [4/6] lemmy-ui 이미지 리빌드 중..."
docker-compose stop lemmy-ui 2>&1
docker-compose rm -f lemmy-ui 2>&1
docker rmi lemmy-ui-custom:latest 2>/dev/null
docker-compose build --no-cache lemmy-ui 2>&1 | tail -5

echo "  [5/6] lemmy-ui 프론트엔드 시작 중..."
docker-compose up -d lemmy-ui 2>&1

echo "  [6/7] bitcoincash-service 재생성 중..."
docker-compose up -d --force-recreate bitcoincash-service 2>&1

echo "  [7/7] content-importer 재생성 중..."
docker-compose up -d --force-recreate content-importer 2>&1

# nginx DNS 캐시 갱신 (recreate로 컨테이너 IP가 바뀌므로 필수)
echo "  🔄 nginx 재시작 중 (upstream IP 갱신)..."
docker-compose restart proxy 2>&1
sleep 2

echo ""
echo "✅ 모든 서비스 재생성 완료"

# 최종 건강 확인
echo ""
echo "🔍 서비스 상태 확인 중..."
sleep 5

if docker exec -i oratio-postgres-1 pg_isready -U lemmy >/dev/null 2>&1; then
    echo "  ✅ PostgreSQL: 정상"
else
    echo "  ❌ PostgreSQL: 비정상"
fi

LEMMY_STATUS=$(docker ps --filter "name=oratio-lemmy-1" --format "{{.Status}}")
echo "  ℹ️  Lemmy: $LEMMY_STATUS"

LEMMYUI_STATUS=$(docker ps --filter "name=oratio-lemmy-ui-1" --format "{{.Status}}")
echo "  ℹ️  Lemmy-UI: $LEMMYUI_STATUS"

echo ""
echo "🎉 완료! 사이트: https://${DOMAIN}"
echo ""
echo "⚠️  주의사항:"
echo "   - RESEND_API_KEY는 직접 설정한 값이 사용됩니다"
echo "   - PAYOUT_WALLET은 직접 설정한 값이 사용됩니다"
echo "   - Admin 로그인: admin / (위에 생성된 패스워드)"
