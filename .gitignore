.env
.env.*
*.env

# refresh_passwords.sh 실제본 (API 키 하드코딩됨, .example 버전이 리포에 올라감)
oratio/refresh_passwords.sh

# lemmy.hjson 실제본 (DB 비밀번호 + pictrs API 키 포함, .example 버전이 리포에 올라감)
oratio/lemmy.hjson

# 보안 관련 파일
*password*
*key*
*secret*
*certificate*
*cert*
*token*
*seed*
*wallet*
*.pem
*.key
wallet_*.sh

# 예외: 실제 비밀번호가 아닌 UI 컴포넌트 (파일명에 password가 포함될 뿐)
!**/password-input.tsx
!**/password-change.tsx

# 예외: 배포용 예제 파일 (.example 접미사)
!*.example
!**/*.example

